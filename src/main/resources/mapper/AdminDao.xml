<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.thesisbuddy.dao.AdminDao">
    
    <!-- 结果映射 -->
    <resultMap id="AdminAccountResultMap" type="org.example.thesisbuddy.entity.AdminAccount">
        <id property="adminId" column="admin_id"/>
        <result property="account" column="account"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="realName" column="real_name"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    
    <!-- 根据账号查询管理员 -->
    <select id="selectByAccount" resultMap="AdminAccountResultMap">
        SELECT admin_id, account, password_hash, real_name, status, create_time 
        FROM admin_account
        WHERE account = #{account}
    </select>
</mapper>
